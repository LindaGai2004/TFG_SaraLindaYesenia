     <script type="text/javascript">(function(f) {var _np=(window.P._namespace("udm-sfx-prime-signup-ingress-script"));if(_np.guardFatal){_np.guardFatal(f)(_np);}else{f(_np);}}(function(P) { P.when('ready').execute("udm-sfx-prime-signup-ingress-handler", () => { P.load.js("https://d2ygma30gaykut.cloudfront.net/SFXInjectableScript.js"); P.when("sfx-injectable").execute("udm-sfx-prime-signup-ingress-flow", async (api) => { const clientId = "DetailPage"; const ingressId = "sdmPrimeUpsell"; const redirectURL = btoa(window.location.pathname); const linkId = "udm-sfx-prime-signup-trigger"; const experienceUUID = api.initiate({ clientId, ingressId, redirectURL, planOptimizationId: "default" }, {}); const ingressButtons = document.querySelectorAll("#" + linkId); ingressButtons.forEach(button => { button.onclick = () => { api.show(experienceUUID); }; }); /* look at the query params to see if we need to open the injectable immediately in the case of sign-in redirect */ const queryString = window.location.search; const urlParams = new URLSearchParams(queryString); const loadInjectableValue = urlParams.get('loadInjectable'); if (loadInjectableValue) { const [currClientId, currIngressId] = loadInjectableValue.split("_"); if (currClientId === clientId && currIngressId === ingressId) { api.show(experienceUUID); } } }); }); }));</script> </span>
