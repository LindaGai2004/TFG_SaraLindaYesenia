                       <div id="spinny-spinner" style="display:none;" data-start-time="">
    <div class="a-section a-text-center">   <img alt="Cargando" src="./como_agua_para_chocolate_files/Spinner._CB575171257_.svg" class="rotate vertical-center"> </div> </div> </button></span></span>   </div>  <script type="text/javascript">
    P.when('jQuery').execute(function($) {
        var SPINNER_TIMED_OUT = "SPINNER_TIMED_OUT";
        var spinner = $("#spinny-spinner");
        var buttonText =  $(".read-sample-button-text");
        if (spinner) {
            $('#pbooksReadSampleButton').click(function () {
                showSpinnerAndHideText();
                setTimeout(function () {
                    if ($("#litb-read-frame").length < 1) {
                        incrementMetric(SPINNER_TIMED_OUT);
                        hideTextAndShowSpinner();
                    }
                }, 30000);
            });
        }
        function showSpinnerAndHideText() {
            if (spinner) {
                spinner.css("display", "block");
                spinner.data("startTime", Math.floor(Date.now() / 1000));
                buttonText.first().css("display","none");
            }
        }
        function hideTextAndShowSpinner() {
            if (spinner) {
                spinner.css("display", "none");
                buttonText.first().css("display", "block");
            }
        }
        function incrementMetric(metricName) {
            if (ue && ue.count && ue.tag) {
                var existingCount = ue.count(metricName) || 0;
                ue.count(metricName, existingCount + 1);
            }
        }
    });
    P.when('A', 'ready').register("PbooksReadSample", function(A) {
        return {
            'litbData': {
                'hasLitb': true,
                'showNewDesktopLitb': true
            }
        };
    });
</script>                             </div>
