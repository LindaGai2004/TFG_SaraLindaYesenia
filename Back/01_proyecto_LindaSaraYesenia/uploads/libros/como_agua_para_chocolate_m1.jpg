PTURE_2.JPG" data-is-vertical-video="false" crossorigin="anonymous"><track data-type="ccTrack" src="https://m.media-amazon.com/images/S/al-eu-726f4d26-7fdb/8c2f7793-1452-4495-9b0d-f4edad5fdb8f.mp4/r/vtt-es-cc.VTT" kind="captions" srclang="es"></video><div id="video-description-ZC5tcDQ=" hidden="">Este anuncio promociona una novela de misterio ambientada en el barrio judío, que entrelaza los acontecimientos históricos de 1389 con los descubrimientos modernos. Promete una historia de intriga basada en hechos reales, centrada en tres niños que descubren un antiguo secreto judío, cautivando a los lectores con giros inesperados.</div><div class="_multi-brand-video-desktop_style_ccContainer__20X2h" data-type="ccContainer" style="visibility: hidden;"><span data-type="ccText" class="a-size-small a-color-inverse _multi-brand-video-desktop_style_ccText__1DgRi"></span></div><div class="_multi-brand-video-desktop_style_videoOverlay__1H_Jm" data-type="videoOverlay"></div></a><div data-type="playIcon" class="_multi-brand-video-desktop_style_playClickRegion__87ZZa" style="visibility: inherit;"><button class="_multi-brand-video-desktop_style_btnContainer__2bAO8" aria-label="Reproducir vídeo patrocinado"><svg width="100%" viewBox="0 0 60 60" version="1.1" xmlns="http://www.w3.org/1999/xlink" role="img"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="SVG-Layer"><g id="Group-7-Copy"><g id="Oval" opacity="0" transform="translate(4.285714, 4.285714)"><g id="path-1-link" fill="#000000" fill-rule="nonzero"><circle id="path-1" cx="25.7142857" cy="25.7142857" r="25.7142857"></circle></g><g id="path-1-link" fill="#FFFFFF"><circle id="path-1" cx="25.7142857" cy="25.7142857" r="25.7142857"></circle></g></g><g id="Group-9" opacity="0.595284598" fill="#000000" fill-rule="nonzero"><circle id="Oval" cx="30" cy="30" r="30"></circle></g></g><g transform="translate(15, 13)"><path d="M33.46 17.08L6.49 1.8C6.33796 1.71454 6.16621 1.67033 5.9918 1.67176C5.81739 1.673