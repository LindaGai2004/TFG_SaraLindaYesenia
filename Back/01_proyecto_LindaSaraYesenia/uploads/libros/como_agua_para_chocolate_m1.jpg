<script type="text/javascript">
    P.when('A','ready').execute(function(A) {
        A.declarative('play-audiosample-cloud-player','click', function(event){
            var data = event.data;
            var cloudPlayerUrl = data.cloudPlayerUrl;
            var audibleAsin = data.asin;
            var type = "AudibleBookSample";
            var cloudPlayerWindow = window.open(cloudPlayerUrl, 'AudibleCloudPlayer', 'width=417, height=625, left=40, top=140');
            if (cloudPlayerWindow == null || typeof(cloudPlayerWindow) == 'undefined') {
                window.location.href = cloudPlayerUrl;
            }

            logCPMetrics(audibleAsin, type);
        });

        function logCPMetrics(asin, subType) {
            A.ajax("/hz/audible/clickstream", {
                type: 'POST',
                dataType: 'json',
                params: {
                    'asin': asin,
                    'event-aud-action': "CONSUMPTION",
                    'event-aud-type': "Listen",
                    'event-aud-subType': subType
                },
                success: function(result){console.log(asin + " " + subType);},
                error: function(result){}
            });
        };
    });

</script>
