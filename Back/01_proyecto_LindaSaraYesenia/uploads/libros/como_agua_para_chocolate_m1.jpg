,&quot;asin&quot;:&quot;8466329080&quot;,&quot;isAiTranslatedWork&quot;:&quot;0&quot;}"> <div id="audiblesampleplayer" class="a-section"> <div class="a-section a-spacing-none audioPlaySample clickablePlayer display-flex horizontal-center"> <span id="cloudPlayerSampleID" class="a-button a-button-base cloud-sample-player-width"><span class="a-button-inner"><input data-test="sampleAudioListen" aria-label="Reproducir Muestra Se abre en una ventana nueva" class="a-button-input" type="submit"><span id="cloudPlayerSampleID-announce" class="a-button-text" aria-hidden="true"> <div class="a-section status-button-container display-flex"> <div class="a-section display-inline">   <img alt="Play" src="./como_agua_para_chocolate_files/Play._CB665605849_.svg" class="playIcon"> <span class="sampleText"> Muestra </span> </div> </div> </span></span></span> </div> </div> </span>  <style type="text/css">
