        A.declarative('aud_title_gift_purchase_action', 'click', function(event) {
            if(event && event.targetTag === "input") {
                if ($(document).data('buttonPressed') !== 'true') {
                    $(document).data('buttonPressed', 'true');
                } else {
                    event.$event.preventDefault();
                }
            }
        });
    });
}));</script> <style>
